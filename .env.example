# Copy to .env and fill in values.

# Set to true to enable /docs and debug logging
DEBUG_MODE=false

# Optional — enables multi-worker session tracking.
# Without this, an in-process dict is used (fine for single-worker / dev).
REDIS_URL=

# ── Jira (skills/jira_ops.py) ─────────────────────────────────────────────────
# Get your API token at: atlassian.com/manage-profile/security/api-tokens
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=IT

# ── Slack (skills/slack_ops.py) ───────────────────────────────────────────────
# Create a webhook at: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# ── Optional AI provider keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
